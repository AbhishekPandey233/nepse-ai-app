# Copy this file to .env and fill in real values. Never commit the real .env.

# MongoDB connection string (must include a database name in the path)
MONGO_URI=mongodb://localhost:27017/nepsebackend

# Secret used to sign JWTs -- generate a random value, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret

# Local Ollama server used by the chat/explainer feature (no API key needed)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
